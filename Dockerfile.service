# Opseeq AI Agent Gateway
# OpenAI-compatible inference proxy + MCP server for agentic use
# Supports: NVIDIA NIM, OpenAI, Anthropic, Ollama, local vLLM
#
# Build:  docker build -f Dockerfile.service -t opseeq:latest .
# Run:    docker run -p 9090:9090 --env-file .env opseeq:latest

# Stage 1: Build TypeScript and install production deps only
FROM node:22-alpine AS builder

WORKDIR /build
COPY service/package.json service/package-lock.json* ./
RUN npm install

COPY service/tsconfig.json ./
COPY service/src/ ./src/
RUN npm run build && rm -rf src/ tsconfig.json && npm prune --production

# Stage 2: Runtime (Alpine — minimal footprint)
FROM node:22-alpine AS runtime

RUN apk add --no-cache curl ca-certificates && adduser -D -h /app opseeq

WORKDIR /app

COPY --from=builder --chown=opseeq:opseeq /build/dist/ ./dist/
COPY --from=builder --chown=opseeq:opseeq /build/node_modules/ ./node_modules/
COPY --chown=opseeq:opseeq service/package.json ./

USER opseeq

ENV NODE_ENV=production
ENV OPSEEQ_HOST=0.0.0.0
ENV OPSEEQ_PORT=9090

EXPOSE 9090

HEALTHCHECK --interval=15s --timeout=5s --retries=3 --start-period=5s \
    CMD curl -f http://localhost:9090/health || exit 1

LABEL org.opencontainers.image.title="Opseeq AI Agent Gateway" \
      org.opencontainers.image.description="Unified inference proxy with MCP for agentic AI services" \
      org.opencontainers.image.version="1.0.0" \
      org.opencontainers.image.source="https://github.com/DylanCkawalec/opseeq"

CMD ["node", "dist/index.js"]
