+  const tools: MirroredTool[] = BUILTIN_TOOLS.map((mod) => ({
+    name: mod.name,
+    sourceHint: mod.sourceHint,
+    execute: (payload: string) => `[tool:${mod.name}] executed with payload: ${payload.slice(0, 80)}`,
+  }));
