+  return {
+    commands,
+    tools,
+    command: (name: string) => commands.find((c) => c.name.toLowerCase() === name.toLowerCase()),
+    tool: (name: string) => tools.find((t) => t.name.toLowerCase() === name.toLowerCase()),
+  };
