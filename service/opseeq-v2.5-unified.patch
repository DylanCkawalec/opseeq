+  let tools = [...BUILTIN_TOOLS];
+  if (simpleMode) {
+    tools = tools.filter((t) => ['Read', 'Write', 'Bash', 'Grep', 'LS'].includes(t.name));
+  }
+  if (pc) {
+    tools = tools.filter((t) => !isToolDenied(t.name, pc));
