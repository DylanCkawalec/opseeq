# Opseeq Copilot env. Copy to .env and edit.
# We also load /Users/dylanckawalec/Desktop/developer/QGoT/.env at boot
# so NVIDIA_API_KEY etc. only need to live in one place.

# ── Server ports ───────────────────────────────────────
COPILOT_API_HOST=127.0.0.1     # local-only by default
COPILOT_API_PORT=7100        # Go GraphQL+REST gateway
COPILOT_WEB_PORT=7101        # Vite dashboard
COPILOT_MCP_PORT=7102        # Optional TS MCP dev server; Go backend uses QGOT_MCP_CMD directly
COPILOT_MCP_TIMEOUT_MS=60000
COPILOT_MCP_EXECUTE_TIMEOUT_MS=300000

# ── Postgres (docker compose default) ──────────────────
DATABASE_URL=postgresql://copilot:copilot@127.0.0.1:5433/copilot

# ── Provider endpoints ─────────────────────────────────
# NVIDIA NIM — sourced from QGoT/.env
QGOT_ENV_PATH=../../QGoT/.env
# (NVIDIA_API_KEY, NVIDIA_BASE_URL, NVIDIA_MODELS picked up from QGOT_ENV_PATH)

# Local Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenAI-compatible (Qwen API, Kimi via Moonshot, GPT-5.1 via OpenAI/OpenRouter)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=

# ── Role → model bindings (initial) ────────────────────
OPSEEQ_OBSERVER_MODEL=nvidia/nemotron-3-super-120b-a12b
OPSEEQ_PLANNER_MODEL=qwen3.5:9b
OPSEEQ_CODER_MODEL=qwen3.5:35b-a3b-coding-mxfp8
OPSEEQ_VERIFIER_MODEL=gpt-oss:20b
OPSEEQ_EXECUTOR_MODEL=gpt-oss:20b

# ── Production QGoT MCP gateway ────────────────────────
QGOT_HTTP_BASE=http://127.0.0.1:7300         # optional qgot-server REST/reference surface
QGOT_MCP_CMD=cargo run -q -p qgot --bin qgot-copilot --features server
QGOT_RUN_DIR=./runs

# Optional TypeScript MCP development bridge compatibility.
# The production Go API does not use these for fallback execution.
QGOT_BRIDGE_TIMEOUT_MS=700
QGOT_BRIDGE_EXECUTE_TIMEOUT_MS=30000

# ── Observability ──────────────────────────────────────
DRIFT_THRESHOLD=0.42
TRACE_ENABLED=true
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama
