{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "outDir": "bin/ts",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@agents/*": ["agents/*"],
      "@workflow/*": ["workflow/*"],
      "@models/*": ["models/*"],
      "@mcp/*": ["mcp/*"],
      "@obs/*": ["obs/*"],
      "@store/*": ["store/*"]
    }
  },
  "include": ["agents/**/*.ts", "workflow/**/*.ts", "models/**/*.ts", "mcp/**/*.ts", "obs/**/*.ts", "store/**/*.ts"],
  "exclude": ["node_modules", "web", "api", "runs", "bin"]
}
