# =============================================================================
# OPSEEQ AI AGENT GATEWAY — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The gateway routes inference requests to the best available provider.
# Configure at least one provider below.
# =============================================================================

# --- Gateway Settings --------------------------------------------------------

# Port for the gateway HTTP server
OPSEEQ_PORT=9090

# API keys for client authentication (comma-separated)
# Leave empty for open access (development only)
OPSEEQ_API_KEYS=

# Default model when none specified in the request
OPSEEQ_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b

# Enable MCP (Model Context Protocol) server for agentic tool use
OPSEEQ_MCP_ENABLED=true

# Serverless mode: auto-shutdown after idle timeout
OPSEEQ_SERVERLESS=false
OPSEEQ_IDLE_TIMEOUT_MS=300000

# Log level: debug | info | warn | error
OPSEEQ_LOG_LEVEL=info

# --- NVIDIA NIM (Highest Priority) ------------------------------------------
# Cloud NIM via NVIDIA API Catalog or self-hosted NIM containers
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODELS=nvidia/nemotron-3-super-120b-a12b,nvidia/llama-3.3-nemotron-super-49b-v1

# --- Self-hosted NIM (Local GPU) --------------------------------------------
# For local NIM containers (docker run nvcr.io/nim/...)
# NIM_LOCAL_URL=http://nim:8000/v1
# NIM_LOCAL_API_KEY=unused
# NIM_LOCAL_MODELS=nvidia/nemotron-3-super-120b-a12b

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODELS=gpt-5.4,gpt-5.2,gpt-4.1,gpt-4.1-mini,gpt-4.1-nano,gpt-4o,gpt-4o-mini,o3,o3-mini,o1,gpt-image-1

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODELS=claude-opus-4-6,claude-sonnet-4-6,claude-haiku-4-5-20251001

# --- SeeQ Model Residency ---------------------------------------------------
# SEEQ_WARM_WINDOW_MS=900000
# SEEQ_ESCALATION_CODE_THRESHOLD=0.4
# SEEQ_ESCALATION_REASON_THRESHOLD=0.8

# --- Ollama (Local) ----------------------------------------------------------
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODELS=gpt-oss:20b,nemotron-3-nano:4b,qwen3-coder:30b,deepseek-r1:32b
